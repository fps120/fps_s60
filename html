<!DOCTYPE html>
<html>
<head>
	<style>
		body{
			background: black;
		}
		p{
			color: white;
		}
		img {
    transition: all 0.3s ease; /* плавность 0.3 секунды */
}

img:hover {
    transform: scale(1.1) rotate(3deg); /* увеличивается на 10% и чуть поворачивается */
    box-shadow: 0 10px 20px rgba(0,0,0,0.3); /* тень для объёма */
    box-shadow: 0 0 30px hotpink; /* розовое свечение */
    /* или жёлтое: 0 0 30px gold */
    /* или голубое: 0 0 30px deepskyblue */
}
h1{
	color: white;
}
h2{
	color: white;
}
/* Стили для кнопок-ссылок (скругление только снизу) */
a{
    display: inline-block;
    padding: 10px 25px;
    background-color: #8a2be2;      /* фиолетовый */
    color: white;
    text-decoration: none;
    font-weight: bold;
    border-radius: 0 0 10px 10px;   /* нет скругления сверху */
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    border: 2px solid #4b0082;
    border-top: none;                /* убираем верхнюю рамку */
}

a:hover{
    background-color: #ff69b4;       /* розовый */
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0,0,0,0.2);
}

	</style>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>Простенький сервачок</title>
</head>
<body>
<p align="center">Простой сервер. ничего удивительного</p>
